def get_daily_quote():
    """获取每日名言"""
    import random
    return random.choice(TECH_QUOTES)

def get_fengshui():
    """获取今日风水"""
    import random
    yi = random.sample(FENGSHUI_DATA['yi'], 3)
    ji = random.sample(FENGSHUI_DATA['ji'], 2)
    return {'yi': yi, 'ji': ji}

# 节日数据
FESTIVALS = {
    (1, 1): '元旦',
    (2, 14): '情人节',
    (3, 8): '妇女节',
    (3, 12): '植树节',
    (4, 1): '愚人节',
    (5, 1): '劳动节',
