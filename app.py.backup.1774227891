class User(UserMixin):
    def __init__(self, id):
        self.id = id
        self.username = ADMIN_USERNAME
    
    def get_id(self):
        return str(self.id)

@login_manager.user_loader
def load_user(user_id):
    if user_id == '1':
        return User(user_id)
    return None

